{
  "name": "generative-ui-component-gym",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run evaluate:specs && npm run build",
    "dev": "vite",
    "evaluate:specs": "tsx scripts/evaluate-specs.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:browser": "playwright test",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^27.0.0",
    "oxlint": "^1.71.0",
    "prettier": "^3.6.0",
    "tsx": "^4.8.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.0.0"
  }
}
